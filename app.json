{
  "expo": {
    "name": "CepteCari",
    "slug": "cepte-cari",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "ceptecari",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "icon": "./assets/cepte-cari-icon-square.png",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ceptecari.mobile",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.ceptecari.mobile",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/cepte-cari-adaptive-square.png",
        "backgroundColor": "#1A0D45"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/cepte-cari-logo-tight.png"
    },
    "splash": {
      "image": "./assets/cepte-cari-logo-tight.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A0D45"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f120cc92-a388-4872-bd32-95fc790982cd"
      }
    },
    "owner": "enes94"
  }
}
