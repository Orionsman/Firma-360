{
  "rewrites": [
    {
      "source": "/privacy-policy",
      "destination": "/privacy-policy.html"
    },
    {
      "source": "/account-deletion",
      "destination": "/account-deletion.html"
    },
    {
      "source": "/terms-of-service",
      "destination": "/terms-of-service.html"
    },
    {
      "source": "/kvkk-notice",
      "destination": "/kvkk-notice.html"
    },
    {
